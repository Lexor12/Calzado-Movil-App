<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#515157"
    android:orientation="vertical"
    >
    <androidx.cardview.widget.CardView
        android:layout_margin="20dp"
        android:layout_height="550dp"
        android:layout_width="350dp"
        app:cardElevation="15dp"
        app:cardCornerRadius="25dp"
        >
        <ImageView
            android:layout_width="350dp"
            android:layout_height="550dp"
            android:alpha=".4"
            android:scaleType="centerCrop"
            android:background="#362b14"
            android:src="@drawable/bg_calzado"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="50dp"
            >
            <TextView
                android:id="@+id/txtNombre"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Nombre"
                />
            <TextView
                android:id="@+id/txtMarca"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Marca"
                />
            <TextView
                android:id="@+id/txtModelo"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Modelo"
                />
            <TextView
                android:id="@+id/txtExistencias"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="# Existencias"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtTipoCalzado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Tipo de calzado"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtMaterial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Material"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtTalla"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Talla"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtColor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Color"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Genero"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtPrecio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Precio $"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/txtTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#242222"
                android:fontFamily="@font/dosis_bold"
                android:textSize="22sp"
                android:text="Teléfono de Contacto"
                />
            <Button
                android:id="@+id/btnLlamar"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Marcar"
                android:backgroundTint="#574043"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:fontFamily="@font/dosis_bold"
                app:icon="@android:drawable/sym_action_call"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <Button
        android:id="@+id/btnRegresar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REGRESAR"
        android:backgroundTint="#1E1E24 "
        android:fontFamily="@font/dosis_bold"
        android:textSize="30sp"
        />
</LinearLayout>